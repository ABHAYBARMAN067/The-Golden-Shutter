# =====================
# Server
# =====================
PORT=5000
CLIENT_ORIGIN=https://your-frontend-domain.com
NODE_ENV=production

# =====================
# MongoDB Atlas
# =====================
# Example: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGO_URI=

# =====================
# Cloudinary
# =====================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional
CLOUDINARY_FOLDER=wedding-gallery

# =====================
# Admin Auth
# =====================
ADMIN_USER=admin
ADMIN_PASS=replace_me

# =====================
# Email (nodemailer)
# =====================
EMAIL_USER=
EMAIL_PASSWORD=
ADMIN_EMAIL=

